# ===== 파이프라인 (GitHub Actions secrets에도 동일하게 등록) =====
DATA_GO_KR_KEY=            # data.go.kr 일반 인증키 (Decoding 키)
LAW_GO_KR_OC=              # open.law.go.kr OC (이메일 @ 앞부분)
CUSTOMS_REQ_ENDPOINT=      # 세관장확인대상물품(GW) 요청주소 — 활용신청 승인 후 Swagger에서 확인
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY= # 파이프라인 전용, 절대 프론트 노출 금지
ANTHROPIC_API_KEY=         # 요약용 (선택 — 없으면 요약 생략)

# ===== 프론트 (web/.env) =====
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
